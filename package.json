{
  "name": "drivehub",
  "private": true,
  "version": "0.1.0",
  "description": "DriveHub — enterprise Car Rental & Car Sales platform (Turborepo monorepo).",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm run prisma:generate --workspace=@drivehub/database",
    "db:migrate": "npm run prisma:migrate --workspace=@drivehub/database",
    "db:seed": "npm run prisma:seed --workspace=@drivehub/database"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
