DATABASE_URL="postgresql://user:password@localhost:5432/drivehub_dev?schema=public"
PORT=4000
WEB_ORIGINS="http://localhost:3000,http://localhost:3100"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:4000"

# Optional — social login is wired up in code but inert until these are set.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Optional — payment providers wired up in code but inert until these are
# set. KHQR QR generation works without any of these (falls back to demo
# merchant values); BAKONG_API_TOKEN is only needed to check payment status.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# ABA_PAYWAY_MERCHANT_ID=
# ABA_PAYWAY_API_KEY=
# ABA_PAYWAY_BASE_URL=
# BAKONG_ACCOUNT_ID=
# BAKONG_MERCHANT_NAME=
# BAKONG_MERCHANT_CITY=
# BAKONG_MERCHANT_ID=
# BAKONG_ACQUIRING_BANK=
# BAKONG_API_TOKEN=

# Optional — email notifications wired up via Resend but inert until these
# are set (in-app notifications and their API work regardless).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Optional — AI Customer Assistant (Sprint 7) wired up for both OpenAI and
# Anthropic but inert until a key is set for whichever AI_PROVIDER selects.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
